rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ====================================================
    // REUSABLE VALIDATION FUNCTIONS
    // ====================================================

    // Ensures the user is authenticated and only modifying their own document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Validates the profile object
    function isValidProfile(profile) {
      // Must be a map
      // Only allow expected fields to prevent bloating or schema drift
      // Validate data types for expected fields if they exist
      return profile is map
        && profile.keys().hasOnly(['name', 'rollNumber', 'createdAt'])
        && (!('name' in profile) || profile.name is string)
        && (!('rollNumber' in profile) || profile.rollNumber is string)
        && (!('createdAt' in profile) || profile.createdAt is string);
    }
    
    // Validates the settings object
    function isValidSettings(settings) {
      // Must be a map
      // Reject unknown fields to keep settings clean
      // Validate types: theme is string, simulationMode is boolean
      return settings is map
        && settings.keys().hasOnly(['theme', 'simulationMode'])
        && (!('theme' in settings) || settings.theme is string)
        && (!('simulationMode' in settings) || settings.simulationMode is bool);
    }

    // Validates the attendance object
    function isValidAttendance(attendance) {
      // Must be a map
      // Do not enforce dynamic keys as they are generated by the engine (e.g. 'YYYY-MM-DD:SUBJ:TYPE')
      return attendance is map;
    }

    // Main document validation
    function isValidStudentDoc(docData) {
      // Reject any unexpected root fields to prevent malformed writes
      return docData.keys().hasOnly(['attendance', 'settings', 'profile'])
        && (!('profile' in docData) || isValidProfile(docData.profile))
        && (!('settings' in docData) || isValidSettings(docData.settings))
        && (!('attendance' in docData) || isValidAttendance(docData.attendance));
    }

    // ====================================================
    // COLLECTION RULES
    // ====================================================

    // Students can only read and write their own document
    // Writes must pass the server-side schema validation
    match /students/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidStudentDoc(request.resource.data);
    }
    
    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}